# === Mode NORMAL (pakai backend sungguhan) ===
# Isi URL backend (tanpa slash akhir). Contoh setelah deploy:
# VITE_API_BASE=https://klinik-api.onrender.com/api
VITE_API_BASE=http://localhost:3002/api

# === Mode DEMO (frontend-only, tanpa backend) ===
# Kalau VITE_API_BASE DIKOSONGKAN atau VITE_DEMO=1 → app pakai data mock in-memory.
# Cocok buat deploy ke Vercel tanpa backend (buat live demo portfolio).
# VITE_DEMO=1
