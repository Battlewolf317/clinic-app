# Copy ke .env lalu sesuaikan
# Koneksi lokal (dipakai kalau DATABASE_URL kosong)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=ganti_password
PGDATABASE=klinik_kulit

# Atau pakai connection string (managed Postgres / Neon):
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

PORT=3002
NODE_ENV=production
JWT_SECRET=ganti_dengan_string_acak_min_16_char
JWT_EXPIRES=8h
CORS_ORIGINS=http://localhost:5175,http://localhost:5173
